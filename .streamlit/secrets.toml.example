# Copy this file to secrets.toml for local dev, OR paste these values
# into the Streamlit Community Cloud "Secrets" panel.
# NEVER commit secrets.toml to git.

CLOUDCALL_API_TOKEN     = "paste-your-access-token-here"
CLOUDCALL_REFRESH_TOKEN = "paste-your-refresh-token-here"
CLOUDCALL_CLIENT_ID     = "o1-public-api"
CLOUDCALL_API_URL       = "https://apio1.cloudcall.com"
CLOUDCALL_AUTH_URL      = "https://auth.cloudcall.com"
